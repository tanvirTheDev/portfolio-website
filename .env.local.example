# ── Sanity CMS ──────────────────────────────────────────────────────────────
# Found at: https://sanity.io/manage → project settings
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API token — needs "Editor" role for seeding; "Viewer" is fine for reads
SANITY_API_TOKEN=

# Webhook shared secret — generate with: openssl rand -hex 32
# Set the same value in Sanity → API → Webhooks → Secret
SANITY_WEBHOOK_SECRET=

# ── Contact form ─────────────────────────────────────────────────────────────
# Get a key at: https://resend.com → API Keys
# If omitted, messages are logged to the server console instead of emailed.
RESEND_API_KEY=

# ── Site metadata & SEO ───────────────────────────────────────────────────────
# Full URL of your production deployment — used in sitemap.xml and robots.txt
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-name.vercel.app
